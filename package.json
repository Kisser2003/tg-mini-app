{
  "name": "tg-mini-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "verify:webhook": "node scripts/verify-webhook-secret.mjs",
    "verify:release-db": "node scripts/verify-release-in-db.mjs",
    "db:types": "supabase gen types typescript --linked > types/database.types.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.49.1",
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.577.0",
    "next": "14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.71.2",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.1.0",
    "postcss": "^8.5.8",
    "supabase": "^2.84.4",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
