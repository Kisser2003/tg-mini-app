NEXT_PUBLIC_APP_URL=https://your-production-domain.example
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Telegram ID администратора (числовой). Используется в lib/admin.ts (isAdminUi).
# Источник истины в БД — таблица admin_users (миграция 20260402120000_admin_users_rbac.sql).
# Чтобы добавить/удалить администратора — INSERT/DELETE в admin_users через Supabase Dashboard.
# Сервер: проверка доступа к /api/admin/*.
ADMIN_TELEGRAM_ID=123456789
# Клиент (Next.js): без этого в production вкладка «Админ» не появится — в бандлер попадают только NEXT_PUBLIC_*.
# Должен совпадать с ADMIN_TELEGRAM_ID.
NEXT_PUBLIC_ADMIN_TELEGRAM_ID=123456789
TELEGRAM_BOT_TOKEN=123456789:replace_with_real_token
# Telegram chat id для отправки admin-уведомлений из notify-admin Edge Function и api/notify-admin.
ADMIN_CHAT_ID=123456789

# Deep-link для кнопки «Открыть админку» в Telegram-уведомлении из Edge Function notify-admin.
# Формат: https://t.me/<bot_username>/app?startapp=admin
# Используется в supabase/functions/notify-admin/index.ts
# Без этой переменной Edge Function использует placeholder и логирует предупреждение.
ADMIN_APP_URL=https://t.me/your_bot_name/app?startapp=admin

# Только development: API без Telegram WebApp (localhost в обычном браузере).
# Задайте оба флага и перезапустите dev — иначе POST /api/releases/* вернёт 401.
# ALLOW_DEV_API_AUTH=true
# NEXT_PUBLIC_ALLOW_DEV_API_AUTH=true

# Shared secret for POST /api/webhooks/release-status-change (must match SQL trigger / pg_net headers).
# ОБЯЗАТЕЛЬНО для production: верификация активна по умолчанию; без этой переменной вебхук вернёт 503.
# Задайте тот же секрет в Supabase → Database Webhooks → HTTP Headers: x-supabase-webhook-secret.
SUPABASE_WEBHOOK_SECRET=replace_with_long_random_string

# Google Gemini: автоматическая QA метаданных перед отправкой (submit-precheck / finalize-submit).
# Без GEMINI_API_KEY проверка ИИ пропускается — дальнейшая модерация вручную.
GEMINI_API_KEY=
# Необязательно; по умолчанию gemini-1.5-flash.
# GEMINI_METADATA_MODEL=gemini-1.5-flash

